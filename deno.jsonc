{
  "lock": false,
  "tasks": {
    "test": "deno test --unstable",
    "prep": "deno fmt && deno test --unstable",
    "bench": "deno bench --unstable"
  },
  "fmt": {
    "semiColons": false,
    "exclude": ["README.md"]
  },
  "test": {
    "include": ["./test/tests"]
  },
  "bench": {
    "include": ["./bench/benches"]
  }
}
